rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['email', 'displayName', 'createdAt']) &&
             data.email is string && data.email.size() < 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             data.createdAt is string;
    }

    function isValidPatient() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'name', 'phoneNumber', 'birthDate', 'age', 'height', 'weight', 'context', 'createdAt']) &&
             data.id is string && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() < 50)) &&
             (!('birthDate' in data) || (data.birthDate is string && data.birthDate.size() < 50)) &&
             (!('age' in data) || (data.age is string && data.age.size() < 10)) &&
             (!('height' in data) || (data.height is string && data.height.size() < 10)) &&
             (!('weight' in data) || (data.weight is string && data.weight.size() < 10)) &&
             (!('context' in data) || (data.context is string && data.context.size() < 10000)) &&
             data.createdAt is string;
    }

    function isValidSessionRecord() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'patientId', 'date', 'rawNotes', 'generatedReport', 'approach', 'templateName']) &&
             data.id is string && data.id.size() < 100 &&
             data.patientId is string && data.patientId.size() < 100 &&
             data.date is string && data.date.size() < 50 &&
             data.rawNotes is string && data.rawNotes.size() < 50000 &&
             (!('generatedReport' in data) || (data.generatedReport is string && data.generatedReport.size() < 100000)) &&
             (!('approach' in data) || (data.approach is string && data.approach.size() < 100)) &&
             (!('templateName' in data) || (data.templateName is string && data.templateName.size() < 100));
    }

    function isValidScheduledSession() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'patientId', 'date', 'time', 'duration', 'status', 'reminderSent', 'reminderSentAt', 'notes']) &&
             data.id is string && data.id.size() < 100 &&
             data.patientId is string && data.patientId.size() < 100 &&
             data.date is string && data.date.size() < 50 &&
             data.time is string && data.time.size() < 20 &&
             data.duration is number && data.duration > 0 && data.duration <= 1440 &&
             data.status in ['scheduled', 'completed', 'cancelled'] &&
             data.reminderSent is bool &&
             (!('reminderSentAt' in data) || (data.reminderSentAt is string && data.reminderSentAt.size() < 50)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 5000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser();
      allow delete: if isOwner(userId);

      match /patients/{patientId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPatient();
        allow update: if isOwner(userId) && isValidPatient();
        allow delete: if isOwner(userId);
      }

      match /sessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSessionRecord();
        allow update: if isOwner(userId) && isValidSessionRecord();
        allow delete: if isOwner(userId);
      }

      match /scheduled_sessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidScheduledSession();
        allow update: if isOwner(userId) && isValidScheduledSession();
        allow delete: if isOwner(userId);
      }
    }

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
